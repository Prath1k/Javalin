.pacman-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 100%;
  height: auto;
  background-color: #000;
  color: #fff;
  font-family: 'Courier New', Courier, monospace;
}

.pacman-header {
  display: flex;
  justify-content: space-between;
  width: 100%;
  max-width: 600px;
  padding: 10px 20px;
  box-sizing: border-box;
  font-size: 1.2rem;
  font-weight: bold;
}

.header-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.canvas-wrapper {
  position: relative;
  width: 100%;
  max-width: 90vw;
  display: flex;
  justify-content: center;
}

.pacman-canvas {
  background-color: #000;
  border: 4px solid #1919A6;
  border-radius: 8px;
  max-width: 100%;
  max-height: 65vh;
  aspect-ratio: 19/21;
  box-shadow: 0 0 20px rgba(25, 25, 166, 0.4);
}

.controls-hint {
  margin-top: 15px;
  font-size: 1rem;
  color: #aaa;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mobile-controls {
  display: none;
  gap: 10px;
  margin-top: 15px;
  flex-direction: column;
  align-items: center;
}

.mobile-row {
  display: flex;
  gap: 15px;
}

@media (max-width: 768px) {
  .controls-hint-text {
    display: none;
  }
  .mobile-controls {
    display: flex;
  }
}

.mc-btn {
  background: rgba(255, 255, 0, 0.2);
  border: 2px solid #ff0;
  color: #ff0;
  width: 50px;
  height: 50px;
  border-radius: 10px;
  font-size: 1.5rem;
  display: flex;
  justify-content: center;
  align-items: center;
  user-select: none;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
}
.mc-btn:active {
  background: rgba(255, 255, 0, 0.5);
}

.game-over-screen {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.85);
  border: 2px solid #ff0;
  padding: 30px;
  text-align: center;
  border-radius: 10px;
  backdrop-filter: blur(5px);
  z-index: 10;
}

.game-over-screen h2 {
  font-size: 2.5rem;
  margin: 0 0 10px 0;
  color: #ff0;
  text-shadow: 0 0 10px #ff0;
}

.pacpac {
  color: #ff0;
}

.red-text { color: #f00; }
.victory-text { color: #0f0; }

.restart-btn {
  margin-top: 20px;
  background: #ff0;
  color: #000;
  border: none;
  padding: 10px 20px;
  font-size: 1.2rem;
  font-family: inherit;
  font-weight: bold;
  cursor: pointer;
  border-radius: 5px;
  transition: all 0.2s;
}

.restart-btn:hover {
  background: #fff;
  box-shadow: 0 0 15px #ff0;
}
